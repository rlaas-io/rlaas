{
  "policies": [
    {
      "policy_id": "p-http-user-fixed",
      "name": "User fixed window",
      "description": "Allow 3 requests/min per user on charge endpoint",
      "enabled": true,
      "priority": 100,
      "scope": {
        "org_id": "acme",
        "tenant_id": "retail",
        "service": "payments",
        "signal_type": "http",
        "endpoint": "/v1/charge",
        "method": "POST",
        "user_id": "u1"
      },
      "algorithm": {
        "type": "fixed_window",
        "limit": 3,
        "window": "1m"
      },
      "action": "deny",
      "failure_mode": "fail_open",
      "enforcement_mode": "enforce",
      "rollout_percent": 100,
      "valid_from_unix": 0,
      "valid_to_unix": 0,
      "metadata": {
        "owner": "example"
      }
    }
  ]
}
